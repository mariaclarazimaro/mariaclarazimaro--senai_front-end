<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercício 38 - Teste A/B</title>
</head>
<body>

    <h1>Teste A/B</h1>

    <button id="botaoA">
        Botão A
    </button>

    <button id="botaoB">
        Botão B
    </button>

    <p>Cliques no Botão A: <span id="contadorA">0</span></p>

    <p>Cliques no Botão B: <span id="contadorB">0</span></p>

    <script>
        let totalA = 0;
        let totalB = 0;

        document.getElementById("botaoA")
            .addEventListener("click", () => {

                totalA++;

                document.getElementById("contadorA")
                    .textContent = totalA;
            });

        document.getElementById("botaoB")
            .addEventListener("click", () => {

                totalB++;

                document.getElementById("contadorB")
                    .textContent = totalB;
            });
    </script>

</body>
</html>