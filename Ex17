<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercício 17 - Contador de Cliques</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 100px;
        }

        button {
            padding: 12px 20px;
            font-size: 16px;
            cursor: pointer;
        }

        p {
            font-size: 24px;
        }
    </style>
</head>
<body>

    <h1>Contador de Cliques</h1>

    <button id="btnClique">Clique aqui</button>

    <p>Quantidade de cliques: <span id="contador">0</span></p>

    <script>
        let cliques = 0;

        const botao = document.getElementById("btnClique");
        const contador = document.getElementById("contador");

        botao.addEventListener("click", function () {
            cliques++;
            contador.textContent = cliques;
        });
    </script>

</body>
</html>