<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercício 32 - Busca em API</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            padding: 30px;
        }

        .container {
            max-width: 700px;
            margin: auto;
            background-color: #ffffff;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 20px 0;
            box-sizing: border-box;
            border: 1px solid #cccccc;
            border-radius: 5px;
            font-size: 16px;
        }

        ul {
            list-style: none;
            padding: 0;
        }

        li {
            padding: 12px;
            margin-bottom: 10px;
            background-color: #f9f9f9;
            border-radius: 5px;
            border-left: 4px solid #333;
        }

        .mensagem {
            text-align: center;
            color: #666;
        }
    </style>
</head>

<body>

    <div class="container">

        <h1>Buscar Usuários</h1>

        <input
            type="text"
            id="busca"
            placeholder="Digite o nome do usuário..."
        >

        <ul id="listaUsuarios"></ul>

        <p class="mensagem" id="mensagem">
            Carregando usuários...
        </p>

    </div>

    <script>
        const campoBusca = document.getElementById("busca");
        const lista = document.getElementById("listaUsuarios");
        const mensagem = document.getElementById("mensagem");

        let usuarios = [];

        fetch("https://jsonplaceholder.typicode.com/users")
            .then(resposta => resposta.json())
            .then(dados => {

                usuarios = dados;

                exibirUsuarios(usuarios);

                mensagem.textContent =
                    "Digite algo para filtrar os resultados.";

            })
            .catch(() => {

                mensagem.textContent =
                    "Erro ao carregar os usuários.";

            });

        function exibirUsuarios(listaUsuarios) {

            lista.innerHTML = "";

            listaUsuarios.forEach(usuario => {

                lista.innerHTML += `
                    <li>
                        <strong>${usuario.name}</strong><br>
                        ${usuario.email}
                    </li>
                `;
            });

            if (listaUsuarios.length === 0) {

                lista.innerHTML =
                    "<li>Nenhum usuário encontrado.</li>";
            }
        }

        campoBusca.addEventListener("input", function () {

            const termo = this.value.toLowerCase();

            const resultado = usuarios.filter(usuario =>
                usuario.name.toLowerCase().includes(termo)
            );

            exibirUsuarios(resultado);
        });
    </script>

</body>
</html>